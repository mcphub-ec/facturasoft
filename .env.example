# ─── FacturaSoft MCP Server ────────────────────────────────────────────────────
# Copia este archivo como .env y completa los valores REALES antes de usar.
#   cp .env.example .env && chmod 600 .env
# ─────────────────────────────────────────────────────────────────────────────

# Bearer Token obtenido desde el panel de FacturaSoft / abitmedia.cloud.
# Se envía en el header Authorization: Bearer <token>.
FACTURASOFT_BEARER_TOKEN=

# (Opcional) URL base de la API.
# FACTURASOFT_BASE_URL=https://api.abitmedia.cloud/facturasoft/v1

# (Opcional) Timeout HTTP en segundos.
# FACTURASOFT_HTTP_TIMEOUT=30

# Opciones: sse | http_stream
MCP_TRANSPORT_MODE=sse
MCP_PORT=8000
